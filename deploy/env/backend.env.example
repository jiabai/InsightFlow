# InsightFlow backend production environment.
# Install this as /etc/insightflow/backend.env with mode 0640 root:insightflow.

SERVER_HOST=127.0.0.1
SERVER_PORT=8080

SQLITE_DB_PATH=/var/lib/insightflow/data/insight_flow.sqlite3
LOCAL_STATUS_STORE_DIR=/var/lib/insightflow/status_store
LOCAL_STORAGE_BASE_DIR=/var/lib/insightflow/upload_file
STORAGE_TYPE=local

INSIGHTFLOW_LOG_LEVEL=INFO
INSIGHTFLOW_LOG_CONSOLE=0
INSIGHTFLOW_LOG_DIR=/var/log/insightflow
INSIGHTFLOW_MAX_CONCURRENT_TASKS=10

LLM_PROVIDER=siliconflow
LLM_API_URL=https://api.siliconflow.cn/v1
LLM_MODEL=deepseek-ai/DeepSeek-V3.2
LLM_TEMPERATURE=0.7
LLM_API_KEY=
